#!/usr/bin/env bash
set -euo pipefail

MODEL="${QWEN3_ASR_MLX_MODEL:-Qwen/Qwen3-ASR-0.6B}"
if [[ $# -gt 0 && "$1" != --* && "$1" == Qwen/* ]]; then
  MODEL="$1"
  shift
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
RUNTIME_ROOT="${QWEN3_ASR_MLX_HOME:-${TRANSCRIBER_QWEN3_ASR_MLX_HOME:-$HOME/.audio-models/runtimes/qwen3-asr-mlx}}"
CACHE_DIR="${QWEN3_ASR_MLX_CACHE_DIR:-$HOME/.audio-models}"
VENV="$RUNTIME_ROOT/venv"
PYTHON_VERSION="${QWEN3_ASR_MLX_PYTHON:-${TRANSCRIBER_QWEN3_ASR_MLX_PYTHON:-3.12}}"
export UV_CACHE_DIR="${UV_CACHE_DIR:-$RUNTIME_ROOT/uv-cache}"
export UV_PYTHON_INSTALL_DIR="${UV_PYTHON_INSTALL_DIR:-$RUNTIME_ROOT/uv-python}"

mkdir -p "$RUNTIME_ROOT" "$UV_CACHE_DIR" "$UV_PYTHON_INSTALL_DIR"

if [[ ! -x "$VENV/bin/python" ]]; then
  if command -v uv >/dev/null 2>&1; then
    uv python install "$PYTHON_VERSION" >&2
    uv venv --python "$PYTHON_VERSION" "$VENV" >&2
  elif command -v "python$PYTHON_VERSION" >/dev/null 2>&1; then
    "python$PYTHON_VERSION" -m venv "$VENV" >&2
  else
    echo "Python $PYTHON_VERSION or uv is required for the Qwen3-ASR MLX perftest." >&2
    exit 2
  fi
fi

PACKAGES=(
  "mlx==0.31.2"
  "mlx-lm==0.29.1"
  "transformers==4.57.6"
  "safetensors==0.8.0"
  "huggingface_hub[cli]==0.36.2"
  "soundfile==0.14.0"
  "librosa==0.11.0"
  "numpy==2.4.6"
  "numba==0.65.1"
  "llvmlite==0.47.0"
  "qwen-asr==0.0.6"
)

PACKAGE_STAMP="$VENV/.qwen3-asr-mlx-packages"
PACKAGE_SPEC="$(printf '%s\n' "${PACKAGES[@]}")"
if [[ ! -f "$PACKAGE_STAMP" ]] || [[ "$(cat "$PACKAGE_STAMP")" != "$PACKAGE_SPEC" ]]; then
  if command -v uv >/dev/null 2>&1; then
    uv pip install --python "$VENV/bin/python" -U "${PACKAGES[@]}" >&2
  else
    "$VENV/bin/python" -m ensurepip --upgrade >&2
    "$VENV/bin/python" -m pip install -U pip >&2
    "$VENV/bin/python" -m pip install -U "${PACKAGES[@]}" >&2
  fi
  printf '%s' "$PACKAGE_SPEC" > "$PACKAGE_STAMP"
fi

exec env PYTHONPATH="$REPO_ROOT${PYTHONPATH:+:$PYTHONPATH}" "$VENV/bin/python" -m qwen3_asr_mlx_runtime.perftest \
  --model "$MODEL" \
  --cache-dir "$CACHE_DIR" \
  "$@"
